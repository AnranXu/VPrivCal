{
  "schemaVersion": "1.0.0",
  "study": {
    "method": "VPrivCal",
    "component": "VPrivCal-Probe",
    "stimulusSet": "private-public-semi-public-v1",
    "description": "Researcher-defined detections for three synthetic egocentric scenes. All identifiers and records are fictional.",
    "askAllAvailableCategories": true,
    "initialDetectionOverlaysHidden": true,
    "participantPointingEnabled": true
  },
  "coordinateSystem": {
    "type": "normalized_xywh",
    "origin": "top-left",
    "range": [
      0,
      1
    ],
    "imageAspectRatio": "1448:1086",
    "hitPadding": 0.012
  },
  "categories": [
    {
      "id": "biometric_data",
      "label": "Biometric Data",
      "description": "Faces and other distinctive physical features that can identify a person."
    },
    {
      "id": "children_images",
      "label": "Children Images",
      "description": "Images or activities involving children."
    },
    {
      "id": "pii",
      "label": "Personally Identifiable Information (PII)",
      "description": "Names, contact details, legal identifiers, digital identifiers, financial information, medical information, location information, and related records."
    },
    {
      "id": "legal_sensitivity_information",
      "label": "Legal Sensitivity Information",
      "description": "Nudity, violent or unlawful acts, weapons, and other legally or culturally sensitive content."
    },
    {
      "id": "personal_life",
      "label": "Personal Life",
      "description": "Home interiors, relationships, personal belongings, family activities, routines, and location context."
    },
    {
      "id": "background_individuals",
      "label": "Background Individuals",
      "description": "Bystanders, passersby, staff, patrons, or other people incidentally captured."
    }
  ],
  "probeQuestions": {
    "awarenessStatus": {
      "id": "awareness_status",
      "prompt": "Before this content was highlighted, which best describes your experience?",
      "options": [
        {
          "value": 1,
          "label": "I had already noticed it and considered the privacy implication."
        },
        {
          "value": 2,
          "label": "I noticed it but had not considered the privacy implication."
        },
        {
          "value": 3,
          "label": "I had not noticed it, or I did not realize the VLM could detect or infer it."
        },
        {
          "value": 4,
          "label": "I do not consider it a privacy concern in this situation."
        }
      ]
    },
    "preferredAction": {
      "id": "preferred_action",
      "prompt": "When similar content appears in the future, what should the assistant do?",
      "options": [
        {
          "value": 0,
          "label": "No intervention"
        },
        {
          "value": 1,
          "label": "Handle it silently"
        },
        {
          "value": 2,
          "label": "Give a brief reminder"
        },
        {
          "value": 3,
          "label": "Ask before using it"
        },
        {
          "value": 4,
          "label": "Avoid using it unless I explicitly request it"
        }
      ]
    }
  },
